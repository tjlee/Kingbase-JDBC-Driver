<?xml version="1.0" encoding="UTF-8"?>
<drivers>
  <driver id="kingbase8" name="KingbaseES" dialect="PostgreSQL" driver-class="com.kingbase8.Driver">
    <url-template name="default" template="jdbc:kingbase8://{host::localhost}[:{port::54321}]/{database::test}[\?&lt;&amp;,user={user},password={password},{:identifier}={:param}&gt;]"/>
    <option name="auto-sync" value="true"/>
    <artifact id="Kingbase8" rolling="true"/>
  </driver>
</drivers>
